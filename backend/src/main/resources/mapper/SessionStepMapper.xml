<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bless.assess.mapper.SessionStepMapper">

    <select id="selectBySessionIdOrderByIndex" resultType="com.bless.assess.entity.SessionStep">
        SELECT * FROM session_step
        WHERE session_id = #{sessionId} AND deleted = 0
        ORDER BY step_index ASC
    </select>

</mapper>
